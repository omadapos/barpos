{
  "name": "bar-pos-client",
  "version": "1.0.0",
  "private": true,
  "description": "Bar POS — punto de venta",
  "author": "Bar POS",
  "main": "electron/main.js",
  "scripts": {
    "dev": "cross-env VITE_API_URL=https://barpos.omadapos.com concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:vps": "npm run dev",
    "clean": "node scripts/clean-build.js",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:vps": "cross-env VITE_API_URL=https://barpos.omadapos.com API_URL=https://barpos.omadapos.com npm run build",
    "rebuild": "node scripts/clean-build.js && tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "test:print-com6": "node scripts/test-print-com.js COM6",
    "test:print-com": "node scripts/test-print-com.js"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "axios": "^1.16.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "node-thermal-printer": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.barpos.client",
    "productName": "BarPOS",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es_ES", "en_US"],
      "language": "1046"
    }
  }
}
